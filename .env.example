# Database configurations (Strictly PostgreSQL)
DB_URL=postgresql://postgres:postgres@localhost:5432/agentic_workspace

# Databricks connection settings for local remote-execution control
DATABRICKS_HOST=https://your-databricks-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiYourDatabricksTokenHere

# LLM Configurations for LangGraph Agents
# If offline generation is used, define your API keys here
OPENAI_API_KEY=mock-key-for-offline
# Or Gemini, etc.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Databricks Foundation Model Serving & MLflow Experiment configurations
# LLM_PROVIDER can be 'gemini' or 'databricks'
LLM_PROVIDER=gemini
DATABRICKS_LLM_ENDPOINT_NAME=databricks-meta-llama-3-1-70b-instruct
DATABRICKS_LLM_EXPERIMENT_ID=

